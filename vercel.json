{
  "rewrites": [
    {
      "source": "/listings/(?!new$|leeds$|manchester$|birmingham$|london$|sheffield$|bristol$|liverpool$|newcastle$|glasgow$|cardiff$)([^/]+)",
      "destination": "/api/public-listing-page?slug=$1"
    },
    {
      "source": "/((?!.*\\.[^/]+$).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/brands/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/equipment/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/listings/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
