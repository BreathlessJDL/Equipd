# Equipd — copy to `.env.local` (gitignored) for local development
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Production builds run `prerender-seo-catalogue.mjs` after `vite build`.
# Vercel must provide the same public Supabase URL + anon key (or service role)
# so approved brand/product HTML can be generated at build time.

# Public product pages: show draft/stale generated content (badged, no draft SEO in meta).
# Defaults to true in Vite dev, false in production builds unless set to true.
# VITE_SHOW_DRAFT_PRODUCT_CONTENT=true

# Production OAuth + email auth: set Supabase Auth Site URL to https://equipd.co.uk (not localhost).
# Redirect URLs must include:
#   https://equipd.co.uk/**
#   https://www.equipd.co.uk/**
#   http://localhost:5174/**
# Google OAuth and email confirmations (signUp emailRedirectTo) use /auth/callback on the current origin.
#
# Auth email branding (confirm signup, password reset, etc.) is configured in Supabase Dashboard
# under Authentication → Emails. Sender name "Equipd" requires Enable Custom SMTP (not app env vars).
# See supabase/auth-email-templates.md.

# Google Maps JavaScript API + Places API (listing location autocomplete)
# VITE_GOOGLE_MAPS_API_KEY=your-browser-api-key

# Google tag / Analytics 4 (client-side; public IDs — not secrets)
# Script loads the Google tag; GA4 is the connected destination in Google Admin.
# Production builds send after analytics consent. Local Vite stays silent unless:
# VITE_GOOGLE_TAG_ID=GT-MK48KZH9
# VITE_GA_MEASUREMENT_ID=G-M5767NZQ85
# VITE_ENABLE_ANALYTICS=true

# Dev seed script only (scripts/seed-dev.mjs) — never commit the service role key
# SUPABASE_URL=https://your-project-id.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SEED_DEV_ALLOW=true

# Bubble CSV test import (scripts/import-bubble-listings-test-batch.mjs)
# BUBBLE_IMPORT_ALLOW=true

# Optional: point the app at locally served Supabase Edge Functions
# VITE_SUPABASE_FUNCTIONS_URL=http://127.0.0.1:54321/functions/v1

# send-support-email Edge Function (support team alerts via Resend)
# RESEND_API_KEY=re_...
# SUPPORT_EMAIL_WEBHOOK_SECRET=generate-a-long-random-secret
# SUPPORT_EMAIL_TO=support@equipd.co.uk
# SUPPORT_EMAIL_FROM=Equipd Support <notifications@equipd.co.uk>
# EQUIPD_APP_URL=https://equipd.co.uk

# SendGrid transactional emails (Phase 1 — scripts + Edge Functions only; never VITE_*)
# SENDGRID_API_KEY=SG.xxx
# SENDGRID_FROM_EMAIL=notifications@equipd.co.uk
# SENDGRID_FROM_NAME=Equipd
# SENDGRID_REPLY_TO_EMAIL=support@equipd.co.uk
# APP_BASE_URL=http://localhost:5174
# EMAIL_TEST_TO=you@example.com
# EMAIL_DRY_RUN=true
# EMAIL_LOGO_URL=https://equipd.co.uk/email/equipd-full-logo.png
# SENDGRID_TEMPLATE_MASTER_TEST=d-xxxxxxxx
# SENDGRID_TEMPLATE_OFFER_RECEIVED=d-xxxxxxxx
# SENDGRID_TEMPLATE_OFFER_ACCEPTED=d-xxxxxxxx
# SENDGRID_TEMPLATE_PAYMENT_SUCCESSFUL=d-xxxxxxxx
# SENDGRID_TEMPLATE_NEW_ORDER_RECEIVED=d-xxxxxxxx
# MARKETPLACE_EMAIL_WEBHOOK_SECRET=your-secret
# See emails/SENDGRID.md for full template env var list.

# intelligence-equipment-research Edge Function (one-time original price + lifecycle enrichment)
# Set in Supabase Dashboard → Edge Functions → Secrets (not VITE_*).
# SERPAPI_API_KEY=your-serpapi-api-key
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4o-mini

# scripts/generate-equipment-product-content.mjs (batch AI product overviews)
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4o-mini

# IndexNow (Bing/Yandex/Naver/Seznam URL change notifications — NOT Google)
# Server/Edge only — never VITE_*. Key is a domain verification token (8-128 [a-zA-Z0-9-]).
#
# Key file delivery (hardened build-time Option A):
# - Production Vercel builds (VERCEL_ENV=production) REQUIRE INDEXNOW_KEY and write
#   public/{INDEXNOW_KEY}.txt (exact body, no newline). File is gitignored.
# - Preview/local builds skip key-file generation and still succeed without the key.
# - Optional local force-write: INDEXNOW_WRITE_KEY_FILE=1
# - Rotation: change INDEXNOW_KEY in Vercel + Supabase Edge secrets, redeploy production.
#
# Vercel Production env: INDEXNOW_KEY=your-stable-indexnow-key
# Supabase Edge Function secrets (indexnow-submit + stripe-webhook notify helper):
#   INDEXNOW_KEY=your-stable-indexnow-key
#   INDEXNOW_INTERNAL_SECRET=long-random-secret-for-cli-service-calls
# Optional CLI live submit: INDEXNOW_KEY=... node scripts/indexnow-submit.mjs --url "https://www.equipd.co.uk/..." --apply
# Optional batch size (1–500, default 100): INDEXNOW_BATCH_SIZE=100

# intelligence-market-search Edge Function (Equipd Intelligence market sync POC)
# Set in Supabase Dashboard → Edge Functions → Secrets (not VITE_*).
# BRAVE_SEARCH_API_KEY=your-brave-search-api-key
# OPENAI_API_KEY=optional-for-future-filtering-extraction

# intelligence-ebay-sold-search Edge Function (Equipd Intelligence eBay sold collector)
# Provider: direct (fetch eBay HTML) or apify (Apify actor scrape).
# EBAY_SOLD_SEARCH_PROVIDER=apify
# APIFY_TOKEN=your-apify-api-token
# APIFY_EBAY_SOLD_ACTOR_ID=caffein.dev/ebay-sold-listings
