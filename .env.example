# Equipd — copy to `.env.local` (gitignored) for local development
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Production OAuth + email auth: set Supabase Auth Site URL to https://equipd.co.uk (not localhost).
# Redirect URLs must include:
#   https://equipd.co.uk/**
#   https://www.equipd.co.uk/**
#   http://localhost:5174/**
# Google OAuth and email confirmations (signUp emailRedirectTo) use /auth/callback on the current origin.
#
# Auth email branding (confirm signup, password reset, etc.) is configured in Supabase Dashboard
# under Authentication → Emails (templates + custom SMTP). See supabase/auth-email-templates.md.

# Google Maps JavaScript API + Places API (listing location autocomplete)
# VITE_GOOGLE_MAPS_API_KEY=your-browser-api-key

# Dev seed script only (scripts/seed-dev.mjs) — never commit the service role key
# SUPABASE_URL=https://your-project-id.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SEED_DEV_ALLOW=true

# Bubble CSV test import (scripts/import-bubble-listings-test-batch.mjs)
# BUBBLE_IMPORT_ALLOW=true

# Optional: point the app at locally served Supabase Edge Functions
# VITE_SUPABASE_FUNCTIONS_URL=http://127.0.0.1:54321/functions/v1

# send-support-email Edge Function (support team alerts via Resend)
# RESEND_API_KEY=re_...
# SUPPORT_EMAIL_WEBHOOK_SECRET=generate-a-long-random-secret
# SUPPORT_EMAIL_TO=support@equipd.co.uk
# SUPPORT_EMAIL_FROM=Equipd Support <notifications@equipd.co.uk>
# EQUIPD_APP_URL=https://equipd.co.uk
